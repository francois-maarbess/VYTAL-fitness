@echo off
set PORT=8080
set DATABASE_URL=postgresql://YOUR_USER:YOUR_PASS@YOUR_HOST:5432/postgres
set DIRECT_URL=%DATABASE_URL%
set GROQ_API_KEY=your_groq_key_here
set CLERK_PUBLISHABLE_KEY=your_pk_test_key_here
set CLERK_SECRET_KEY=your_sk_test_key_here
set CLERK_WEBHOOK_SECRET=whsec_placeholder
set USDA_API_KEY=DEMO_KEY
:start
echo [%date% %time%] Starting API server on port %PORT%...
node artifacts/api-server/dist/index.mjs
echo [%date% %time%] Server exited. Restarting in 2 seconds...
timeout /t 2 /nobreak >nul
goto start
