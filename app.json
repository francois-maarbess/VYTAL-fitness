{
  "expo": {
    "name": "VYTAL Fitness",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#060A14"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "package": "com.francis.aifitnesscoach",
      "backgroundColor": "#060A14",
      "permissions": [
        "android.permission.health.READ_STEPS"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "router": {
        "origin": "https://replit.com/"
      },
      "eas": {
        "projectId": "903e5f49-fc1c-4ee3-a990-80ae35db5877"
      }
    }
  }
}
